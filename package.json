{
  "name": "private-otc",
  "version": "0.1.0",
  "private": true,
  "description": "On-chain OTC desk with hidden amounts and Vickrey-fair price discovery, built on iExec Nox protocol",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "contracts:build": "pnpm --filter contracts build",
    "contracts:test": "pnpm --filter contracts test",
    "contracts:deploy:sepolia": "pnpm --filter contracts deploy:sepolia",
    "agents:dev": "pnpm --filter agents dev",
    "mcp:dev": "pnpm --filter mcp-server dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.4.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  }
}
