{
  "name": "private-otc",
  "version": "0.1.0",
  "private": true,
  "description": "On-chain OTC desk with hidden amounts and Vickrey-fair price discovery, built on iExec Nox protocol",
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prepare": "husky",
    "contracts:build": "pnpm --filter contracts build",
    "contracts:test": "pnpm --filter contracts test",
    "contracts:deploy:sepolia": "pnpm --filter contracts deploy:sepolia",
    "agents:dev": "pnpm --filter agents dev",
    "mcp:dev": "pnpm --filter mcp-server dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "prettier": "^3.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "packages/web/**/*.{ts,tsx}": "bash -c 'pnpm --filter web type-check'",
    "packages/mcp-server/**/*.ts": "bash -c 'pnpm --filter mcp-server exec tsc --noEmit'",
    "packages/agents/**/*.ts": "bash -c 'pnpm --filter agents exec tsc --noEmit'"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
